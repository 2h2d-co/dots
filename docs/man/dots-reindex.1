.SH NAME
dots-reindex - Rebuild the active profile database from repo files


.SH SYNOPSIS
\fBdots reindex [flags]\fP


.SH DESCRIPTION
Rebuild the active profile database from the current profile files. If the repo has a configured git upstream, reindex refuses to run unless there is nothing to pull from the remote.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for reindex


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config\fP=""
	config file path (overrides DOTS_CONFIG; default $XDG_CONFIG_HOME/dots/config.toml or ~/.config/dots/config.toml)

.PP
\fB--profile\fP=""
	profile name (overrides DOTS_PROFILE and default_profile)


.SH SEE ALSO
\fBdots(1)\fP


