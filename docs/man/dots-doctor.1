.SH NAME
dots-doctor - Check one or all profiles for issues


.SH SYNOPSIS
\fBdots doctor [flags]\fP


.SH DESCRIPTION
Run status checks for all configured profiles, or only the overridden profile when --profile or DOTS_PROFILE is set. Doctor exits 0 when every checked profile is clean and 1 when any checked profile needs attention.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for doctor


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config\fP=""
	config file path (overrides DOTS_CONFIG; default $XDG_CONFIG_HOME/dots/config.toml or ~/.config/dots/config.toml)

.PP
\fB--profile\fP=""
	profile name (overrides DOTS_PROFILE and default_profile)


.SH SEE ALSO
\fBdots(1)\fP


