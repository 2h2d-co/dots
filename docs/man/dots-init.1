.SH NAME
dots-init - Initialize dots config and a configured profile


.SH SYNOPSIS
\fBdots init REPO [flags]\fP


.SH DESCRIPTION
Initialize or extend dots config, the dotfiles repository, one profile directory, and SQLite tracking databases. A profile is required via --profile or DOTS_PROFILE.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for init


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config\fP=""
	config file path (overrides DOTS_CONFIG; default $XDG_CONFIG_HOME/dots/config.toml or ~/.config/dots/config.toml)

.PP
\fB--profile\fP=""
	profile name (overrides DOTS_PROFILE and default_profile)


.SH SEE ALSO
\fBdots(1)\fP


