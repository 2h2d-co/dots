.SH NAME
dots-completion - Generate shell completion scripts


.SH SYNOPSIS
\fBdots completion [bash|zsh|fish|powershell] [flags]\fP


.SH DESCRIPTION
Generate shell completion scripts. Source the output from your shell startup file or install it in the appropriate completions directory.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for completion


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config\fP=""
	config file path (overrides DOTS_CONFIG; default $XDG_CONFIG_HOME/dots/config.toml or ~/.config/dots/config.toml)

.PP
\fB--profile\fP=""
	profile name (overrides DOTS_PROFILE and config profile)


.SH SEE ALSO
\fBdots(1)\fP


