.SH NAME
dots-apply - Preview or copy tracked files to the home directory


.SH SYNOPSIS
\fBdots apply [flags]\fP


.SH DESCRIPTION
Preview or copy tracked files from the active profile to the home directory. Apply always performs a full preflight check before changing files; --force backs up conflicting destinations before overwriting them.


.SH OPTIONS
\fB--dry-run\fP[=false]
	show what would be applied without changing files

.PP
\fB--force\fP[=false]
	back up and overwrite conflicting destination files

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for apply


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config\fP=""
	config file path (overrides DOTS_CONFIG; default $XDG_CONFIG_HOME/dots/config.toml or ~/.config/dots/config.toml)

.PP
\fB--profile\fP=""
	profile name (overrides DOTS_PROFILE and config profile)


.SH SEE ALSO
\fBdots(1)\fP


